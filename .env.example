PORT=8787
# Description: Local API port for the Express server.
# Used in: server/config/env.ts, server/index.ts
# Obtain it by: Choosing an open local/server port.

APP_URL=http://localhost:5173
# Description: Canonical app URL used by the backend for Stripe return URLs, Clerk invite redirects, and email links.
# Used in: server/config/env.ts, server/routes/auth.ts, server/routes/payments.ts
# Obtain it by: Your local URL in development and your production domain in Vercel.

NEXT_PUBLIC_APP_URL=http://localhost:5173
# Description: Public frontend app URL. Vite is configured to expose NEXT_PUBLIC_* variables to the client.
# Used in: src/config/env.ts, server/config/env.ts
# Obtain it by: The same public URL you use for APP_URL.

DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Description: Supabase pooled Postgres connection string for the runtime Prisma client on Vercel/local API.
# Used in: prisma/schema.prisma, server/config/env.ts
# Obtain it by: Supabase Dashboard -> Connect -> Connection string -> Transaction pooler.

DIRECT_DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
# Description: Direct Supabase Postgres connection string used by Prisma migrations and schema introspection.
# Used in: prisma/schema.prisma, server/config/env.ts
# Obtain it by: Supabase Dashboard -> Connect -> Connection string -> Direct connection.

NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
# Description: Public Supabase project URL.
# Used in: src/config/env.ts, server/config/env.ts
# Obtain it by: Supabase Dashboard -> Project Settings -> Data API -> Project URL.

NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_or_anon_key
# Description: Public Supabase key for browser-side Supabase integrations.
# Used in: src/config/env.ts, server/config/env.ts
# Obtain it by: Supabase Dashboard -> Project Settings -> Data API -> Project API keys -> anon or publishable key.

SUPABASE_SERVICE_ROLE_KEY=sb_service_role_key
# Description: Server-only Supabase service role key for admin workflows or future Supabase server APIs.
# Used in: server/config/env.ts
# Obtain it by: Supabase Dashboard -> Project Settings -> Data API -> Project API keys -> service_role key.

CLERK_SECRET_KEY=sk_test_replace_me
# Description: Clerk secret key used by the Express API for auth validation, user/org sync, and org invitations.
# Used in: server/config/env.ts, server/lib/auth.ts, server/routes/auth.ts
# Obtain it by: Clerk Dashboard -> API Keys -> Secret key.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
# Description: Public Clerk publishable key used by the React frontend.
# Used in: src/config/env.ts, src/main.tsx, server/config/env.ts
# Obtain it by: Clerk Dashboard -> API Keys -> Publishable key.

CLERK_PUBLISHABLE_KEY=pk_test_replace_me
# Description: Optional backend-side alias for the Clerk publishable key.
# Used in: server/config/env.ts
# Obtain it by: Clerk Dashboard -> API Keys -> Publishable key.

CLERK_SIGN_IN_URL=/sign-in
# Description: Frontend sign-in route.
# Used in: server/config/env.ts, server/routes/auth.ts, src/main.tsx
# Obtain it by: Keeping the default auth route or matching your custom sign-in route.

CLERK_SIGN_UP_URL=/sign-up
# Description: Frontend sign-up route.
# Used in: server/config/env.ts, src/main.tsx
# Obtain it by: Keeping the default auth route or matching your custom sign-up route.

CLERK_AFTER_SIGN_IN_URL=/dashboard
# Description: Default internal route after sign-in.
# Used in: server/config/env.ts
# Obtain it by: Choosing the route authenticated users should land on.

CLERK_AFTER_SIGN_UP_URL=/onboarding
# Description: Default internal route after sign-up.
# Used in: server/config/env.ts
# Obtain it by: Choosing the route new users should land on.

CLERK_INVITATION_REDIRECT_URL=http://localhost:5173/sign-in
# Description: Full URL Clerk uses in organization invitations.
# Used in: server/config/env.ts, server/routes/auth.ts
# Obtain it by: Your deployed sign-in URL or local sign-in URL.

STRIPE_SECRET_KEY=sk_test_replace_me
# Description: Stripe secret key used for subscriptions, invoice payments, billing portal, and webhook-linked records.
# Used in: server/config/env.ts, server/lib/stripe.ts, server/routes/payments.ts
# Obtain it by: Stripe Dashboard -> Developers -> API keys -> Secret key.

STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Description: Stripe webhook signing secret for /api/payments/webhook.
# Used in: server/config/env.ts, server/routes/payments.ts
# Obtain it by: Stripe Dashboard -> Developers -> Webhooks -> select endpoint -> Signing secret.

STRIPE_PRICE_STARTER=price_replace_me
# Description: Stripe recurring price ID for the Starter plan.
# Used in: server/config/env.ts, server/routes/payments.ts
# Obtain it by: Stripe Dashboard -> Product catalog -> Starter product -> recurring price.

STRIPE_PRICE_PROFESSIONAL=price_replace_me
# Description: Stripe recurring price ID for the Professional plan.
# Used in: server/config/env.ts, server/routes/payments.ts
# Obtain it by: Stripe Dashboard -> Product catalog -> Professional product -> recurring price.

STRIPE_PRICE_AGENCY=price_replace_me
# Description: Stripe recurring price ID for the Agency plan.
# Used in: server/config/env.ts, server/routes/payments.ts
# Obtain it by: Stripe Dashboard -> Product catalog -> Agency product -> recurring price.

RESEND_API_KEY=re_replace_me
# Description: Resend API key for invoice, payment, project update, and invitation emails.
# Used in: server/config/env.ts, server/lib/resend.ts, server/lib/email.ts
# Obtain it by: Resend Dashboard -> API Keys.

RESEND_FROM_EMAIL=Client Portal <no-reply@example.com>
# Description: Verified sender used for transactional email.
# Used in: server/config/env.ts, server/lib/email.ts
# Obtain it by: Resend Dashboard -> Domains/Senders -> verified sender identity.

SENTRY_DSN=
# Description: Backend Sentry DSN for Express/API error monitoring.
# Used in: server/config/env.ts, server/lib/sentry.ts
# Obtain it by: Sentry Project Settings -> Client Keys (DSN) for your backend project.

VITE_SENTRY_DSN=
# Description: Frontend Sentry DSN for browser/runtime monitoring.
# Used in: src/config/env.ts, src/main.tsx, src/utils/logger.ts
# Obtain it by: Sentry Project Settings -> Client Keys (DSN) for your frontend project.

VITE_APP_NAME=Client Portal
# Description: Public product name.
# Used in: src/config/env.ts, src/components/AppLayout.tsx, src/pages/LoginPage.tsx, src/pages/SignUpPage.tsx
# Obtain it by: Choosing your customer-facing brand name.

VITE_APP_SUBTITLE=Projects & Invoices
# Description: Public product subtitle.
# Used in: src/config/env.ts, src/components/AppLayout.tsx
# Obtain it by: Choosing a short descriptor for the portal.

VITE_API_BASE_URL=
# Description: Optional API origin override when the frontend and API are not served from the same domain.
# Used in: src/config/env.ts, src/lib/api.ts
# Obtain it by: Setting the full API origin only if you split frontend/API origins.

VITE_SUPPORT_EMAIL=support@example.com
# Description: Public support contact shown in the frontend.
# Used in: src/config/env.ts, src/components/AppErrorBoundary.tsx, src/pages/SettingsPage.tsx
# Obtain it by: Your support mailbox.

VITE_APP_URL=http://localhost:5173
# Description: Backward-compatible Vite alias for NEXT_PUBLIC_APP_URL.
# Used in: src/config/env.ts, server/config/env.ts
# Obtain it by: Using the same value as NEXT_PUBLIC_APP_URL.

VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
# Description: Backward-compatible Vite alias for NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY.
# Used in: src/config/env.ts, src/main.tsx, server/config/env.ts
# Obtain it by: Using the same value as NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY.

DEV_SEED_ADMIN_CLERK_USER_ID=user_seed_admin
# Description: Optional Clerk user ID linked to the seeded admin record.
# Used in: prisma/seed.ts
# Obtain it by: Creating a Clerk test user and copying the user ID, or leaving the default placeholder.

DEV_SEED_MANAGER_CLERK_USER_ID=user_seed_manager
# Description: Optional Clerk user ID linked to the seeded manager record.
# Used in: prisma/seed.ts
# Obtain it by: Creating a Clerk test user and copying the user ID, or leaving the default placeholder.

DEV_SEED_CLIENT_CLERK_USER_ID=user_seed_client
# Description: Optional Clerk user ID linked to the seeded client record.
# Used in: prisma/seed.ts
# Obtain it by: Creating a Clerk test user and copying the user ID, or leaving the default placeholder.

DEV_SEED_CLERK_ORG_ID=org_seed_acme
# Description: Optional Clerk organization ID linked to the seeded organization.
# Used in: prisma/seed.ts
# Obtain it by: Creating a Clerk test organization and copying the organization ID, or leaving the default placeholder.
