PORT=8787
# Description: Local API port for the Express server.
# Used in: server/config/env.ts, server/index.ts
# Obtain it by: Choosing an open local/server port. Keep 8787 unless your environment requires another port.

APP_URL=http://localhost:5173
# Description: Canonical public app URL used for Stripe success/cancel URLs, Clerk invite redirects, and email links.
# Used in: server/config/env.ts, server/routes/auth.ts, server/routes/payments.ts
# Obtain it by: Your local URL in development and your production domain in Vercel.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/client_portal
# Description: PostgreSQL connection string for Prisma and the API.
# Used in: prisma/schema.prisma, server/config/env.ts
# Obtain it by: Creating a Postgres database locally or with Neon, Supabase, Railway, RDS, or another managed Postgres provider.

CLERK_PUBLISHABLE_KEY=pk_test_replace_me
# Description: Clerk publishable key used by Clerk redirect configuration and available as a server-side fallback.
# Used in: server/config/env.ts
# Obtain it by: Clerk Dashboard -> API Keys -> Publishable key.

VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
# Description: Public Clerk publishable key used by the React frontend.
# Used in: src/config/env.ts, src/main.tsx
# Obtain it by: Clerk Dashboard -> API Keys -> Publishable key.

CLERK_SECRET_KEY=sk_test_replace_me
# Description: Clerk secret key used by the Express API to validate sessions, sync users/orgs, and create invitations.
# Used in: Clerk middleware/runtime, server/config/env.ts, server/lib/auth.ts, server/routes/auth.ts
# Obtain it by: Clerk Dashboard -> API Keys -> Secret key.

CLERK_SIGN_IN_URL=/sign-in
# Description: Path used by the API when it returns sign-in redirects.
# Used in: server/config/env.ts, server/routes/auth.ts
# Obtain it by: Keeping the frontend auth route path or matching your custom auth route.

CLERK_SIGN_UP_URL=/sign-up
# Description: Path used by Clerk and the API for sign-up redirects.
# Used in: server/config/env.ts, src/main.tsx
# Obtain it by: Keeping the frontend auth route path or matching your custom auth route.

CLERK_AFTER_SIGN_IN_URL=/dashboard
# Description: Default internal post-login route for users who already belong to an organization.
# Used in: server/config/env.ts
# Obtain it by: Choosing the route users should land on after authentication.

CLERK_AFTER_SIGN_UP_URL=/onboarding
# Description: Default internal post-sign-up route for users who need to create/select an organization.
# Used in: server/config/env.ts
# Obtain it by: Choosing the onboarding route in your frontend.

CLERK_INVITATION_REDIRECT_URL=http://localhost:5173/sign-in
# Description: Full URL used in Clerk organization invitations.
# Used in: server/config/env.ts, server/routes/auth.ts
# Obtain it by: Using your deployed sign-in page URL or local sign-in URL in development.

STRIPE_SECRET_KEY=sk_test_replace_me
# Description: Stripe secret key used to create subscriptions, invoice checkout sessions, customer portal sessions, and webhook verification.
# Used in: server/config/env.ts, server/lib/stripe.ts, server/routes/payments.ts
# Obtain it by: Stripe Dashboard -> Developers -> API keys -> Secret key.

STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Description: Stripe webhook signing secret used to verify `/api/payments/webhook`.
# Used in: server/config/env.ts, server/routes/payments.ts
# Obtain it by: Stripe Dashboard -> Developers -> Webhooks -> Select endpoint -> Signing secret.

STRIPE_PRICE_STARTER=price_replace_me
# Description: Stripe recurring price ID for the Starter plan.
# Used in: server/config/env.ts, server/routes/payments.ts
# Obtain it by: Stripe Dashboard -> Product catalog -> Starter product -> recurring price ID.

STRIPE_PRICE_PROFESSIONAL=price_replace_me
# Description: Stripe recurring price ID for the Professional plan.
# Used in: server/config/env.ts, server/routes/payments.ts
# Obtain it by: Stripe Dashboard -> Product catalog -> Professional product -> recurring price ID.

STRIPE_PRICE_AGENCY=price_replace_me
# Description: Stripe recurring price ID for the Agency plan.
# Used in: server/config/env.ts, server/routes/payments.ts
# Obtain it by: Stripe Dashboard -> Product catalog -> Agency product -> recurring price ID.

RESEND_API_KEY=re_replace_me
# Description: Resend API key used to send invoice, payment, project update, and invite emails.
# Used in: server/config/env.ts, server/lib/resend.ts, server/lib/email.ts
# Obtain it by: Resend Dashboard -> API Keys.

RESEND_FROM_EMAIL=Client Portal <no-reply@example.com>
# Description: Verified sender used for transactional emails.
# Used in: server/config/env.ts, server/lib/email.ts
# Obtain it by: Resend Dashboard -> Domains/Senders. Use a verified sender identity.

SENTRY_DSN=
# Description: Server-side Sentry DSN for API error monitoring.
# Used in: server/config/env.ts, server/lib/sentry.ts
# Obtain it by: Sentry Project Settings -> Client Keys (DSN) for your backend/server project.

VITE_SENTRY_DSN=
# Description: Browser Sentry DSN for frontend runtime monitoring.
# Used in: src/config/env.ts, src/main.tsx, src/utils/logger.ts
# Obtain it by: Sentry Project Settings -> Client Keys (DSN) for your frontend/browser project.

VITE_APP_NAME=Client Portal
# Description: Public product name rendered in the shell and auth screens.
# Used in: src/config/env.ts, src/components/AppLayout.tsx, src/pages/LoginPage.tsx, src/pages/SignUpPage.tsx
# Obtain it by: Choosing the brand name shown to end users.

VITE_APP_SUBTITLE=Projects & Invoices
# Description: Short product subtitle shown in the application shell.
# Used in: src/config/env.ts, src/components/AppLayout.tsx
# Obtain it by: Choosing a short descriptor for your deployment.

VITE_APP_URL=http://localhost:5173
# Description: Public frontend origin used by the client runtime.
# Used in: src/config/env.ts, src/pages/SettingsPage.tsx
# Obtain it by: Your local frontend URL in development and your production domain in Vercel.

VITE_API_BASE_URL=
# Description: Optional API origin override for the frontend. Leave empty when the frontend and API share a domain or when using the local Vite proxy.
# Used in: src/config/env.ts, src/lib/api.ts
# Obtain it by: Setting the full API origin only when the API is hosted on a different domain.

VITE_SUPPORT_EMAIL=support@example.com
# Description: Public support contact shown in the frontend.
# Used in: src/config/env.ts, src/components/AppErrorBoundary.tsx, src/pages/SettingsPage.tsx
# Obtain it by: Using your customer-facing support mailbox.

DEV_SEED_ADMIN_CLERK_USER_ID=user_seed_admin
# Description: Optional Clerk user ID linked to the seeded admin record.
# Used in: prisma/seed.ts
# Obtain it by: Creating a Clerk test user and copying the user ID, or leaving the default placeholder for development-only seed data.

DEV_SEED_MANAGER_CLERK_USER_ID=user_seed_manager
# Description: Optional Clerk user ID linked to the seeded manager record.
# Used in: prisma/seed.ts
# Obtain it by: Creating a Clerk test user and copying the user ID, or leaving the default placeholder for development-only seed data.

DEV_SEED_CLIENT_CLERK_USER_ID=user_seed_client
# Description: Optional Clerk user ID linked to the seeded client record.
# Used in: prisma/seed.ts
# Obtain it by: Creating a Clerk test user and copying the user ID, or leaving the default placeholder for development-only seed data.

DEV_SEED_CLERK_ORG_ID=org_seed_acme
# Description: Optional Clerk organization ID linked to the seeded organization.
# Used in: prisma/seed.ts
# Obtain it by: Creating a Clerk test organization and copying the organization ID, or leaving the default placeholder for development-only seed data.
