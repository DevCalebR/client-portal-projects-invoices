VITE_APP_NAME=Client Portal
# Description: Public app name shown in the header, login page, and settings.
# Used in: src/config/env.ts, src/components/AppLayout.tsx, src/pages/LoginPage.tsx, src/pages/SettingsPage.tsx
# Obtain it by: Choosing the product/brand name you want shown to users.

VITE_APP_SUBTITLE=Projects & Invoices
# Description: Short subtitle displayed in the shell header and settings page.
# Used in: src/config/env.ts, src/components/AppLayout.tsx, src/pages/SettingsPage.tsx
# Obtain it by: Choosing a short descriptor for this deployment.

VITE_SUPPORT_EMAIL=support@example.com
# Description: Public support contact shown in the login page, error boundary, and settings.
# Used in: src/config/env.ts, src/components/AppErrorBoundary.tsx, src/pages/LoginPage.tsx, src/pages/SettingsPage.tsx
# Obtain it by: Using the customer-facing support mailbox for this environment.

VITE_ENABLE_DEMO_MODE=true
# Description: Enables the seeded demo credential helpers and demo-oriented copy.
# Used in: src/config/env.ts, src/pages/LoginPage.tsx, src/pages/SettingsPage.tsx
# Obtain it by: Setting true for demo/staging use or false for a branded deployment.

VITE_SESSION_TIMEOUT_MINUTES=480
# Description: Session lifetime before the client auto-expires the local session.
# Used in: src/config/env.ts, src/context/AuthContext.tsx, src/pages/SettingsPage.tsx
# Obtain it by: Choosing the session duration policy for this deployment.
